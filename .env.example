# Copy this to .env and fill in:
#   cp .env.example .env

# Your miner private key. NEVER commit the real .env file.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE_64_HEX_CHARS

# Base mainnet RPC. Public node works; for serious mining use Alchemy/QuickNode/Helius.
RPC_URL=https://mainnet.base.org

# Optional: explicit thread count (0 = auto-detect cores).
# MINER_THREADS=4
